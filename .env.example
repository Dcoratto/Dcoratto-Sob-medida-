# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Firebase Admin credentials for server routes like /api/calendar-feed
FIREBASE_PROJECT_ID="ai-studio-applet-webapp-2ecc9"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@ai-studio-applet-webapp-2ecc9.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIRESTORE_DATABASE_ID="ai-studio-1e79ab13-281e-49ca-b45c-a24a4386b051"

# Supabase client configuration for the frontend and server routes
VITE_SUPABASE_URL="https://rgenylmqqfjqwnpyjlsx.supabase.co"
VITE_SUPABASE_ANON_KEY="sb_publishable_dZ84zzSZsg3A1P3LxHtB7A_O3Bp6osu"
SUPABASE_URL="https://rgenylmqqfjqwnpyjlsx.supabase.co"
SUPABASE_ANON_KEY="sb_publishable_dZ84zzSZsg3A1P3LxHtB7A_O3Bp6osu"

# Optional: only needed to migrate Firebase files into Supabase Storage automatically
SUPABASE_SERVICE_ROLE_KEY="YOUR_SERVICE_ROLE_KEY"
SUPABASE_SITE_URL="http://127.0.0.1:3000"

